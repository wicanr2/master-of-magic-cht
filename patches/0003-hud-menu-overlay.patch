+// chtButtonLabel:中文化共用疊字 — 在烘進圖的按鈕上先填深色擦掉英文 (保留外框),
+// 再用 InfoFontYellow 疊銳利中文 (rule 81:CJK 用 font 畫在高解析緩衝)。
+func (game *Game) chtButtonLabel(screen *ebiten.Image, rect image.Rectangle, img *ebiten.Image, label string) {
+    if label == "" || game.Fonts == nil || game.Fonts.InfoFontYellow == nil || img == nil {
+        return
+    }
+    S := scale.ScaleAmount
+    bw := float64(img.Bounds().Dx())
+    bh := float64(img.Bounds().Dy())
+    vector.DrawFilledRect(screen,
+        float32((float64(rect.Min.X)+3)*S), float32((float64(rect.Min.Y)+2)*S),
+        float32((bw-6)*S), float32((bh-4)*S),
+        color.RGBA{R: 40, G: 26, B: 12, A: 255}, false)
+    game.Fonts.InfoFontYellow.PrintOptions(screen,
+        float64(rect.Min.X)+bw/2, float64(rect.Min.Y)+2,
+        font.FontOptions{Justify: font.FontJustifyCenter, Scale: S, DropShadow: true}, label)
+}
