+func (game *Game) chtButtonLabel(screen *ebiten.Image, rect image.Rectangle, img *ebiten.Image, label string) {
+    fnt := game.Fonts.ChtMenuFont
+    if label == "" || game.Fonts == nil || fnt == nil || img == nil {
+        return
+    }
+    S := scale.ScaleAmount
+    bw := float64(img.Bounds().Dx())
+    bh := float64(img.Bounds().Dy())
+    vector.DrawFilledRect(screen,
+        float32((float64(rect.Min.X)+2)*S), float32((float64(rect.Min.Y)+1)*S),
+        float32((bw-4)*S), float32((bh-2)*S),
+        color.RGBA{R: 58, G: 44, B: 30, A: 255}, false)
+    fnt.PrintOptions(screen,
+        float64(rect.Min.X)+bw/2, float64(rect.Min.Y)+float64(bh)/2-float64(fnt.Height())/2,
+        font.FontOptions{Justify: font.FontJustifyCenter, Scale: S, DropShadow: true}, label)
+}
