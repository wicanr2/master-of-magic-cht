+package main
+
+// 重現 issue3-A:法術描述數字變亂碼。用 spell.go 同款 spellTextNormalFont(fonts[0]),
+// 把同一句分別用 RenderWrapped(描述路徑) vs PrintOptions(施法費用路徑) 畫出來比對。
+
+import (
+	"image"
+	"image/color"
+	"image/png"
+	"os"
+
+	"github.com/kazzmir/master-of-magic/lib/lbx"
+	"github.com/kazzmir/master-of-magic/lib/font"
+	"github.com/kazzmir/master-of-magic/game/magic/audio"
+	"github.com/kazzmir/master-of-magic/game/magic/mouse"
+	"github.com/kazzmir/master-of-magic/game/magic/data"
+	"github.com/kazzmir/master-of-magic/game/magic/scale"
+	"github.com/hajimehoshi/ebiten/v2"
+)
+
+type Engine struct{ f *font.Font; n int }
+
+func (e *Engine) Update() error { e.n++; return nil }
+func (e *Engine) Layout(int, int) (int, int) { return 960, 300 }
+
+func (e *Engine) Draw(screen *ebiten.Image) {
+	screen.Fill(color.RGBA{R: 200, G: 180, B: 130, A: 255}) // 羊皮紙底
+	mud := "Turns a 5x5 area into thick sticky mud for the duration of a battle."
+	star := "A 15 strength attack that is only effective versus Chaos and Death creatures."
+	var op ebiten.DrawImageOptions
+	fo := font.FontOptions{Scale: scale.ScaleAmount, Options: &op}
+	// (a) 描述路徑:RenderWrapped
+	e.f.RenderWrapped(screen, 10, 10, e.f.CreateWrappedText(130, 1, mud), fo)
+	// (b) 施法費用路徑:直接 PrintOptions(同一句,不 wrap)
+	e.f.PrintOptions(screen, 10, 120, fo, mud)
+	// (c) 另一句確認
+	e.f.PrintOptions(screen, 10, 160, fo, star)
+	// (d) 對照:純英文施法費用樣式
+	e.f.PrintOptions(screen, 10, 200, fo, "Casting cost:30 (1 turn) 5x5 15")
+
+	if e.n == 8 {
+		b := screen.Bounds()
+		buf := make([]byte, 4*b.Dx()*b.Dy())
+		screen.ReadPixels(buf)
+		img := &image.NRGBA{Pix: buf, Stride: 4 * b.Dx(), Rect: image.Rect(0, 0, b.Dx(), b.Dy())}
+		f, _ := os.Create("/out/repro.png")
+		png.Encode(f, img)
+		f.Close()
+		os.Exit(0)
+	}
+}
+
+func main() {
+	cache := lbx.AutoCache()
+	audio.Initialize()
+	mouse.Initialize()
+	fontLbx, _ := cache.GetLbxFile("fonts.lbx")
+	fonts, _ := font.ReadFonts(fontLbx, 0)
+	greyLight := color.RGBA{R: 20, G: 20, B: 20, A: 255}
+	pal := color.Palette{
+		color.RGBA{R: 0, G: 0, B: 0, A: 0},
+		color.RGBA{R: 20, G: 20, B: 20, A: 255},
+		greyLight, greyLight, greyLight, greyLight, greyLight, greyLight,
+	}
+	f := font.MakeOptimizedFontWithPalette(fonts[6], pal)  // ALIEN
+	ebiten.SetWindowSize(data.ScreenWidth*3, data.ScreenHeight*3)
+	ebiten.RunGame(&Engine{f: f})
+}
