diff --git a/game/magic/artifact/cht_cost_test.go b/game/magic/artifact/cht_cost_test.go
new file mode 100644
index 0000000..86cc483
--- /dev/null
+++ b/game/magic/artifact/cht_cost_test.go
@@ -0,0 +1,37 @@
+package artifact
+
+// 驗證 issue #2:製造神器的施法成本是否 = 神器法力成本(手冊:時間取決於神器成本/施法技能/每回合法力)。
+// 本測試直接驗 calculateCost 的成本計算,確認貴神器的成本確實高(而非便宜)。
+
+import (
+    "testing"
+)
+
+func TestChtArtifactCost(test *testing.T) {
+    // 空神器(無附魔):各類型 base 成本
+    sword := &Artifact{Type: ArtifactTypeSword}
+    misc := &Artifact{Type: ArtifactTypeMisc}
+    staff := &Artifact{Type: ArtifactTypeStaff}
+
+    costs := map[Power]int{}
+
+    test.Logf("空神器 base 成本: 劍=%d 雜項=%d 法杖=%d", calculateCost(sword, costs), calculateCost(misc, costs), calculateCost(staff, costs))
+
+    if calculateCost(sword, costs) != 100 {
+        test.Errorf("劍 base 應 100,得 %d", calculateCost(sword, costs))
+    }
+
+    // 加幾個高成本 power(模擬玩家做的「三四千的東西」)
+    p1 := Power{Type: PowerTypeAttack, Amount: 6}
+    p2 := Power{Type: PowerTypeDefense, Amount: 6}
+    costs[p1] = 1600
+    costs[p2] = 1600
+    expensive := &Artifact{Type: ArtifactTypeSword, Powers: []Power{p1, p2}}
+    cost := calculateCost(expensive, costs)
+    test.Logf("加 2 個 1600 成本 power 的劍 → 總成本 %d (應 = 100 + 1600 + 1600 = 3300)", cost)
+    if cost != 3300 {
+        test.Errorf("成本計算異常:期望 3300,得 %d", cost)
+    }
+    test.Logf(">>> calculateCost 正確加總(base + 各 power);若玩家神器顯示 3-4000,created.Cost 也應 3-4000")
+    test.Logf(">>> 成本流:created.Cost→spell.OverrideCost→player.CastingSpell→多回合 ComputeEffectiveSpellCost(尊重 OverrideCost)")
+}
