diff --git a/game/magic/combat/cht_repro_test.go b/game/magic/combat/cht_repro_test.go
new file mode 100644
index 0000000..795c383
--- /dev/null
+++ b/game/magic/combat/cht_repro_test.go
@@ -0,0 +1,98 @@
+package combat
+
+// 重現 issue #1:玩家走進有怪物的據點,直接「你已戰敗」,連擺陣開打都沒有。
+// 假說:doCombat.createArmy (game.go:4618) 的地形過濾在特定戰場把玩家單位全濾掉 → 空軍隊 → 秒敗。
+// 本測試複製該過濾邏輯,用數值+地形直接驗,不需遊玩。
+
+import (
+    "testing"
+
+    "github.com/kazzmir/master-of-magic/game/magic/data"
+    "github.com/kazzmir/master-of-magic/game/magic/units"
+    playerlib "github.com/kazzmir/master-of-magic/game/magic/player"
+    herolib "github.com/kazzmir/master-of-magic/game/magic/hero"
+    "github.com/kazzmir/master-of-magic/game/magic/setup"
+)
+
+func chtMakeOW(u units.Unit) units.StackUnit {
+    return units.MakeOverworldUnitFromUnit(u, 0, 0, data.PlaneArcanus, data.BannerBlue, &units.NoExperienceInfo{}, &units.NoEnchantments{})
+}
+
+// 複製 game.go doCombat.createArmy 的地形過濾
+func chtBuildArmy(player *playerlib.Player, stack []units.Unit, landscape CombatLandscape) *Army {
+    army := &Army{Player: player}
+    for _, u := range stack {
+        ow := chtMakeOW(u)
+        if !ow.IsFlying() {
+            if landscape == CombatLandscapeWater && ow.IsLandWalker() {
+                continue
+            }
+            if landscape != CombatLandscapeWater && ow.IsSailing() {
+                continue
+            }
+        }
+        army.AddUnit(ow)
+    }
+    return army
+}
+
+func TestChtEncounterArmyFilter(test *testing.T) {
+    human := playerlib.MakePlayer(setup.WizardCustom{}, true, 1, 1, map[herolib.HeroType]string{}, &playerlib.NoGlobalEnchantments{})
+
+    for _, u := range []units.Unit{units.BarbarianSpearmen, units.HighMenSpearmen, units.Trireme, units.Galley} {
+        ow := chtMakeOW(u)
+        test.Logf("單位 %-18s IsFlying=%-5v IsLandWalker=%-5v IsSailing=%v", u.Name, ow.IsFlying(), ow.IsLandWalker(), ow.IsSailing())
+    }
+
+    land := []units.Unit{units.BarbarianSpearmen, units.BarbarianSpearmen}
+    grass := chtBuildArmy(human, land, CombatLandscapeGrass)
+    water := chtBuildArmy(human, land, CombatLandscapeWater)
+    test.Logf("陸軍(矛兵x2) → grass 戰場: %d 單位 / water 戰場: %d 單位", len(grass.units), len(water.units))
+
+    // 船運陸軍:船 + 陸軍,攻水上據點
+    shipPlusLand := []units.Unit{units.Trireme, units.BarbarianSpearmen, units.BarbarianSpearmen}
+    waterMixed := chtBuildArmy(human, shipPlusLand, CombatLandscapeWater)
+    test.Logf("船+陸軍 → water 戰場: %d 單位 (船是否還在)", len(waterMixed.units))
+
+    if len(water.units) == 0 {
+        test.Logf(">>> #1 重現:純陸軍在水域戰場被全濾掉 → 空軍隊 → 必秒敗")
+    }
+    if len(grass.units) == 0 {
+        test.Errorf("意外:陸軍在 grass 戰場也被濾空(這才是廣泛 bug)")
+    }
+
+    // 驗證修正邏輯(Classic):過濾若導致空軍隊,保留被濾單位讓其開打。
+    classicWater := chtBuildArmyClassic(human, land, CombatLandscapeWater)
+    test.Logf("修正後(Classic)陸軍 → water 戰場: %d 單位 (應 >0,不再秒敗)", len(classicWater.units))
+    if len(classicWater.units) == 0 {
+        test.Errorf("修正失敗:Classic 模式陸軍在 water 仍被濾空")
+    }
+}
+
+// chtBuildArmyClassic 複製 game.go 修正後的 createArmy (Classic:濾空則保留)。
+func chtBuildArmyClassic(player *playerlib.Player, stack []units.Unit, landscape CombatLandscape) *Army {
+    army := &Army{Player: player}
+    added := 0
+    var filtered []units.StackUnit
+    for _, u := range stack {
+        ow := chtMakeOW(u)
+        if !ow.IsFlying() {
+            if landscape == CombatLandscapeWater && ow.IsLandWalker() {
+                filtered = append(filtered, ow)
+                continue
+            }
+            if landscape != CombatLandscapeWater && ow.IsSailing() {
+                filtered = append(filtered, ow)
+                continue
+            }
+        }
+        army.AddUnit(ow)
+        added += 1
+    }
+    if added == 0 && len(filtered) > 0 {
+        for _, ow := range filtered {
+            army.AddUnit(ow)
+        }
+    }
+    return army
+}
