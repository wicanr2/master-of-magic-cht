diff --git a/lib/font/override.go b/lib/font/override.go
new file mode 100644
index 0000000..61d2d31
--- /dev/null
+++ b/lib/font/override.go
@@ -0,0 +1,113 @@
+package font
+
+// 字串覆蓋層 (顯示層翻譯) —— 工作魔法大帝中文化。
+//
+// 設計重點 (見 ADR 0003):翻譯**只在顯示層**做,不碰引擎邏輯字串。
+// 因為引擎把英文名稱當邏輯 key 比對 (例 artifact/create-artifact.go:198
+// `if string(name) == "+6 Defense"`),若在資料讀取層改成中文會破壞遊戲邏輯。
+// 因此在 lib/font 的繪字進入點 (doPrint / PrintOutline / MeasureTextWidth) 把
+// 顯示字串換成中文,引擎內部仍用英文。
+//
+// 比對採 **trim 後精確比對**:引擎讀 LBX 名稱時會 bytes.Trim 去前後空白
+// (create-artifact.go:149),故表的 key 與輸入都先 TrimSpace 再查。
+//
+// 翻譯表來源:環境變數 MOM_CHT_STRINGS 指向一個目錄,載入其中所有 *.tsv
+// (欄位 source<TAB>zh<TAB>note,# 開頭與 header 略過)。未設定或查無對應時回傳原字串,
+// 不影響英文顯示。
+
+import (
+	"bufio"
+	"embed"
+	"io"
+	"os"
+	"path/filepath"
+	"strings"
+	"sync"
+)
+
+// 內嵌譯文表:standalone 出包不依賴 MOM_CHT_STRINGS。env 仍可覆寫 (env 先載、先到先得)。
+//
+//go:embed cht_strings/*.tsv
+var embeddedStrings embed.FS
+
+var (
+	overrideOnce  sync.Once
+	overrideTable = map[string]string{}
+)
+
+func loadOverrideTable() {
+	// 1) 環境變數目錄優先 (dev 可覆寫內嵌表)
+	if dir := os.Getenv("MOM_CHT_STRINGS"); dir != "" {
+		if entries, err := os.ReadDir(dir); err == nil {
+			for _, e := range entries {
+				if e.IsDir() || !strings.HasSuffix(strings.ToLower(e.Name()), ".tsv") {
+					continue
+				}
+				if f, err := os.Open(filepath.Join(dir, e.Name())); err == nil {
+					loadOverrideReader(f)
+					f.Close()
+				}
+			}
+		}
+	}
+	// 2) 內嵌表補齊 (先到先得,env 已載的不覆寫)
+	if entries, err := embeddedStrings.ReadDir("cht_strings"); err == nil {
+		for _, e := range entries {
+			if !strings.HasSuffix(strings.ToLower(e.Name()), ".tsv") {
+				continue
+			}
+			if data, err := embeddedStrings.ReadFile("cht_strings/" + e.Name()); err == nil {
+				loadOverrideReader(strings.NewReader(string(data)))
+			}
+		}
+	}
+}
+
+func loadOverrideReader(r io.Reader) {
+	scanner := bufio.NewScanner(r)
+	scanner.Buffer(make([]byte, 0, 64*1024), 1024*1024)
+	for scanner.Scan() {
+		line := scanner.Text()
+		if line == "" || strings.HasPrefix(strings.TrimSpace(line), "#") {
+			continue
+		}
+		cols := strings.Split(line, "\t")
+		if len(cols) < 2 {
+			continue
+		}
+		src := strings.TrimSpace(cols[0])
+		zh := strings.TrimSpace(cols[1])
+		if src == "" || src == "source" || zh == "" {
+			continue // 略過 header 與空譯文
+		}
+		// help 等含 0x14 換行碼的 entry:TSV 以字面 \n 表示,載入時還原成 NewLine(0x14),
+		// 讓 source 與引擎實際顯示字串精確比對、zh 也保有換行 (一般 entry 無 \n,無副作用)。
+		src = strings.ReplaceAll(src, "\\n", "\x14")
+		zh = strings.ReplaceAll(zh, "\\n", "\x14")
+		// 先到先得:不覆寫已存在的 key (讓較早載入的表優先;同義變體可並存)
+		if _, exists := overrideTable[src]; !exists {
+			overrideTable[src] = zh
+		}
+	}
+}
+
+// translateForDisplay 把要顯示的字串換成中文 (trim 後精確比對)。
+// 表為空或查無對應時回傳原字串。引擎邏輯字串不受影響 (本函式只在繪字時呼叫)。
+func translateForDisplay(text string) string {
+	overrideOnce.Do(loadOverrideTable)
+	if len(overrideTable) == 0 {
+		return text
+	}
+	if zh, ok := overrideTable[strings.TrimSpace(text)]; ok {
+		return zh
+	}
+	return text
+}
+
+// TranslateFormat 翻譯 fmt.Sprintf 格式字串模板 (呼叫端在 Sprintf 之前使用)。
+// 例:TranslateFormat("Do you wish to abort your %v spell?") 返回「您確定要中止施放 %v 嗎?」,
+// 呼叫端再 fmt.Sprintf(TranslateFormat(template), spellName) 組出完整中文句。
+// 比對失敗時回傳原模板,不影響英文顯示。
+func TranslateFormat(template string) string {
+	return translateForDisplay(template)
+}
