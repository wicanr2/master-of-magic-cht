@@ -0,0 +1,74 @@
+package main
+
+// 中文化 dumper:用引擎讀出建築名/描述 + help entries 的精確英文字串,供翻譯。
+// help body 的 0x14 換行碼轉成字面 "\n" 方便處理 (翻完寫回 TSV 時再轉回 0x14)。
+import (
+	"fmt"
+	"os"
+	"strings"
+
+	"github.com/kazzmir/master-of-magic/lib/lbx"
+	"github.com/kazzmir/master-of-magic/game/magic/building"
+	helplib "github.com/kazzmir/master-of-magic/game/magic/help"
+)
+
+func esc(s string) string {
+	s = strings.ReplaceAll(s, "\x14", "\\n")
+	s = strings.ReplaceAll(s, "\t", " ")
+	s = strings.ReplaceAll(s, "\n", "\\n")
+	s = strings.ReplaceAll(s, "\r", "")
+	return s
+}
+
+func main() {
+	cache := lbx.AutoCache()
+
+	// 建築名 + 描述
+	bf, _ := os.Create("/out/buildings_en.tsv")
+	defer bf.Close()
+	fmt.Fprintln(bf, "source\tzh\tnote")
+	infos, err := building.ReadBuildingInfo(cache)
+	desc := building.MakeBuildDescriptions(cache)
+	if err == nil {
+		seen := map[string]bool{}
+		for b := building.Building(1); b < building.BuildingLast; b++ {
+			name := infos.Name(b)
+			if name != "" && !seen[name] {
+				seen[name] = true
+				fmt.Fprintf(bf, "%s\t\t建築名\n", esc(name))
+			}
+			d := desc.Get(b)
+			if d != "" && !seen[d] {
+				seen[d] = true
+				fmt.Fprintf(bf, "%s\t\t建築描述\n", esc(d))
+			}
+		}
+	} else {
+		fmt.Println("building err:", err)
+	}
+
+	// help.lbx 全 entries
+	hf, _ := os.Create("/out/help_en.tsv")
+	defer hf.Close()
+	fmt.Fprintln(hf, "headline\tsource_body\tzh_body")
+	lbxFile, err := cache.GetLbxFile("help.lbx")
+	if err == nil {
+		help, err := helplib.ReadHelp(lbxFile, 2)
+		if err == nil {
+			fmt.Printf("HELP ENTRIES: %d\n", len(help.Entries))
+			n := 0
+			for _, e := range help.Entries {
+				if strings.TrimSpace(e.Text) == "" {
+					continue
+				}
+				fmt.Fprintf(hf, "%s\t%s\t\n", esc(e.Headline), esc(e.Text))
+				n++
+			}
+			fmt.Printf("HELP NON-EMPTY: %d\n", n)
+		} else {
+			fmt.Println("help err:", err)
+		}
+	} else {
+		fmt.Println("help lbx err:", err)
+	}
+}
