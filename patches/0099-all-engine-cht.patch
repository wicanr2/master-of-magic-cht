diff --git a/game/magic/game/advice.go b/game/magic/game/advice.go
new file mode 100644
index 0000000..ae73d63
--- /dev/null
+++ b/game/magic/game/advice.go
@@ -0,0 +1,61 @@
+package game
+
+// 自動建議(Automatic Advice)顯示層:把 player.GenerateAdvice 產生的結構化建議轉成中文訊息,
+// 在人類回合開始時(設定開啟)以卷軸彈出。建議規則由 MoM 玩家攻略歸納(見 player/advice.go)。
+
+import (
+    "fmt"
+    "strings"
+
+    "github.com/kazzmir/master-of-magic/lib/font"
+    playerlib "github.com/kazzmir/master-of-magic/game/magic/player"
+)
+
+func adviceMessage(advice playerlib.Advice) string {
+    switch advice.Type {
+        case playerlib.AdviceNegativeGold:
+            return font.TranslateFormat("You are losing gold each turn. Raise taxes, build a marketplace, or dismiss costly units.")
+        case playerlib.AdviceNegativeFood:
+            return font.TranslateFormat("You are short of food. Your troops will starve - add farmers in your cities.")
+        case playerlib.AdviceNegativeMana:
+            return font.TranslateFormat("You are losing mana each turn. Adjust your magic, meld nodes, or build religious buildings.")
+        case playerlib.AdviceNoResearch:
+            return font.TranslateFormat("You are not researching any spell. Choose one in your spell book.")
+        case playerlib.AdviceCityRebels:
+            if advice.City != nil {
+                return fmt.Sprintf(font.TranslateFormat("%v has rebels. Add a garrison, build religious buildings, or lower taxes."), advice.City.Name)
+            }
+        case playerlib.AdviceCityNoGarrison:
+            if advice.City != nil {
+                return fmt.Sprintf(font.TranslateFormat("%v has no garrison and cannot defend itself."), advice.City.Name)
+            }
+    }
+    return ""
+}
+
+// maybeShowAdvice:設定開啟時,依目前狀態產生建議並以卷軸彈給人類玩家(無建議則不彈)。
+func (game *Game) maybeShowAdvice(player *playerlib.Player) {
+    gold := player.GoldPerTurn()
+    food := player.FoodPerTurn()
+    mana := player.ManaPerTurn(game.Model.ComputePower(player), game.Model)
+
+    advice := player.GenerateAdvice(gold, food, mana)
+    if len(advice) == 0 {
+        return
+    }
+
+    var lines []string
+    for _, item := range advice {
+        if message := adviceMessage(item); message != "" {
+            lines = append(lines, message)
+        }
+    }
+    if len(lines) == 0 {
+        return
+    }
+
+    select {
+        case game.Events <- &GameEventScroll{Title: "ADVICE", Text: strings.Join(lines, "\n")}:
+        default:
+    }
+}
