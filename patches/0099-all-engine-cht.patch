new file mode 100644
index 0000000..84ff70b
--- /dev/null
+++ b/test/cht-dump/main.go
@@ -0,0 +1,107 @@
+package main
+
+// 中文化 dumper:用引擎讀出建築名/描述 + help entries 的精確英文字串,供翻譯。
+// help body 的 0x14 換行碼轉成字面 "\n" 方便處理 (翻完寫回 TSV 時再轉回 0x14)。
+import (
+	"fmt"
+	"os"
+	"strings"
+
+	"github.com/kazzmir/master-of-magic/lib/lbx"
+	"github.com/kazzmir/master-of-magic/game/magic/building"
+	citylib "github.com/kazzmir/master-of-magic/game/magic/city"
+	helplib "github.com/kazzmir/master-of-magic/game/magic/help"
+	spelllib "github.com/kazzmir/master-of-magic/game/magic/spellbook"
+)
+
+func esc(s string) string {
+	s = strings.ReplaceAll(s, "\x14", "\\n")
+	s = strings.ReplaceAll(s, "\t", " ")
+	s = strings.ReplaceAll(s, "\n", "\\n")
+	s = strings.ReplaceAll(s, "\r", "")
+	return s
+}
+
+func main() {
+	cache := lbx.AutoCache()
+
+	// 建築名 + 描述
+	bf, _ := os.Create("/out/buildings_en.tsv")
+	defer bf.Close()
+	fmt.Fprintln(bf, "source\tzh\tnote")
+	infos, err := building.ReadBuildingInfo(cache)
+	desc := building.MakeBuildDescriptions(cache)
+	if err == nil {
+		seen := map[string]bool{}
+		for b := building.Building(1); b < building.BuildingLast; b++ {
+			name := infos.Name(b)
+			if name != "" && !seen[name] {
+				seen[name] = true
+				fmt.Fprintf(bf, "%s\t\t建築名\n", esc(name))
+			}
+			d := desc.Get(b)
+			if d != "" && !seen[d] {
+				seen[d] = true
+				fmt.Fprintf(bf, "%s\t\t建築描述\n", esc(d))
+			}
+		}
+	} else {
+		fmt.Println("building err:", err)
+	}
+
+	// 城市名池 (cityname.lbx)
+	if names, err := citylib.ReadCityNames(cache); err == nil {
+		cf, _ := os.Create("/out/citynames_en.tsv")
+		for _, n := range names {
+			if strings.TrimSpace(n) != "" {
+				fmt.Fprintf(cf, "%s\t\t城市名\n", esc(n))
+			}
+		}
+		cf.Close()
+		fmt.Printf("CITY NAMES: %d\n", len(names))
+	} else {
+		fmt.Println("cityname err:", err)
+	}
+
+	// desc.lbx 全法術描述(施法卷軸顯示的那段,Effects/Target/Casting Cost/Upkeep + 描述)
+	if descs, err := spelllib.ReadSpellDescriptionsFromCache(cache); err == nil {
+		sf, _ := os.Create("/out/spelldesc_en.tsv")
+		fmt.Fprintln(sf, "source\tzh\tnote")
+		n := 0
+		for _, d := range descs {
+			if strings.TrimSpace(d) != "" {
+				fmt.Fprintf(sf, "%s\t\t法術描述\n", esc(d))
+				n++
+			}
+		}
+		sf.Close()
+		fmt.Printf("SPELL DESCRIPTIONS: %d non-empty / %d total\n", n, len(descs))
+	} else {
+		fmt.Println("spelldesc err:", err)
+	}
+
+	// help.lbx 全 entries
+	hf, _ := os.Create("/out/help_en.tsv")
+	defer hf.Close()
+	fmt.Fprintln(hf, "headline\tsource_body\tzh_body")
+	lbxFile, err := cache.GetLbxFile("help.lbx")
+	if err == nil {
+		help, err := helplib.ReadHelp(lbxFile, 2)
+		if err == nil {
+			fmt.Printf("HELP ENTRIES: %d\n", len(help.Entries))
+			n := 0
+			for _, e := range help.Entries {
+				if strings.TrimSpace(e.Text) == "" {
+					continue
+				}
+				fmt.Fprintf(hf, "%s\t%s\t\n", esc(e.Headline), esc(e.Text))
+				n++
+			}
+			fmt.Printf("HELP NON-EMPTY: %d\n", n)
+		} else {
+			fmt.Println("help err:", err)
+		}
+	} else {
+		fmt.Println("help lbx err:", err)
+	}
+}
diff --git a/test/cht-settings/main.go b/test/cht-settings/main.go
new file mode 100644
index 0000000..90254cb
--- /dev/null
+++ b/test/cht-settings/main.go
@@ -0,0 +1,107 @@
+package main
+
+// 中文化驗證 harness:渲染設定畫面(settings.MakeSettingsUI),第 N 幀把畫面存成 PNG 後結束。
+// 用途:headless 目視驗證設定畫面雙欄版面 + 11 個 toggle 的中文與排版(不撞 OK 鈕)。
+// 跑法:cwd 指向遊戲 LBX 目錄(AutoCache 會找到),xvfb 下執行,輸出 /out/settings.png。
+
+import (
+    "image"
+    "image/png"
+    "log"
+    "os"
+
+    "github.com/kazzmir/master-of-magic/lib/lbx"
+    "github.com/kazzmir/master-of-magic/game/magic/settings"
+    "github.com/kazzmir/master-of-magic/game/magic/audio"
+    musiclib "github.com/kazzmir/master-of-magic/game/magic/music"
+    "github.com/kazzmir/master-of-magic/game/magic/data"
+    "github.com/kazzmir/master-of-magic/game/magic/util"
+    "github.com/kazzmir/master-of-magic/game/magic/scale"
+    uilib "github.com/kazzmir/master-of-magic/game/magic/ui"
+    "github.com/kazzmir/master-of-magic/game/magic/mouse"
+
+    "github.com/hajimehoshi/ebiten/v2"
+)
+
+type Engine struct {
+    UI      *uilib.UI
+    counter int
+    outPath string
+}
+
+func NewEngine() (*Engine, error) {
+    cache := lbx.AutoCache()
+    imageCache := util.MakeImageCache(cache)
+    music := musiclib.MakeMusic(cache)
+
+    ui := &uilib.UI{
+        Draw: func(ui *uilib.UI, screen *ebiten.Image) {
+            ui.IterateElementsByLayer(func(element *uilib.UIElement) {
+                if element.Draw != nil {
+                    element.Draw(element, screen)
+                }
+            })
+        },
+    }
+    ui.SetElementsFromArray(nil)
+
+    group, _ := settings.MakeSettingsUI(cache, &imageCache, music)
+    ui.AddGroup(group)
+
+    out := os.Getenv("SHOT")
+    if out == "" {
+        out = "/out/settings.png"
+    }
+
+    return &Engine{UI: ui, outPath: out}, nil
+}
+
+func (engine *Engine) Update() error {
+    engine.UI.StandardUpdate()
+    engine.counter++
+    return nil
+}
+
+func (engine *Engine) Draw(screen *ebiten.Image) {
+    engine.UI.Draw(engine.UI, screen)
+
+    // fade-in 為 7 幀;第 20 幀已完全顯示,截圖後結束。
+    if engine.counter == 20 {
+        bounds := screen.Bounds()
+        buf := make([]byte, 4*bounds.Dx()*bounds.Dy())
+        screen.ReadPixels(buf)
+        img := &image.NRGBA{Pix: buf, Stride: 4 * bounds.Dx(), Rect: image.Rect(0, 0, bounds.Dx(), bounds.Dy())}
+        f, err := os.Create(engine.outPath)
+        if err != nil {
+            log.Printf("create png: %v", err)
+            os.Exit(1)
+        }
+        if err := png.Encode(f, img); err != nil {
+            log.Printf("encode png: %v", err)
+        }
+        f.Close()
+        log.Printf("wrote %v (%dx%d)", engine.outPath, bounds.Dx(), bounds.Dy())
+        os.Exit(0)
+    }
+}
+
+func (engine *Engine) Layout(outsideWidth, outsideHeight int) (int, int) {
+    return scale.Scale2(data.ScreenWidth, data.ScreenHeight)
+}
+
+func main() {
+    log.SetFlags(log.Lshortfile)
+    ebiten.SetWindowSize(data.ScreenWidth*3, data.ScreenHeight*3)
+    ebiten.SetWindowTitle("cht-settings")
+    audio.Initialize()
+    mouse.Initialize()
+
+    engine, err := NewEngine()
+    if err != nil {
+        log.Printf("init: %v", err)
+        return
+    }
+    if err := ebiten.RunGame(engine); err != nil {
+        log.Printf("run: %v", err)
+    }
+}
diff --git a/test/cht-verify-i18n/main.go b/test/cht-verify-i18n/main.go
new file mode 100644
index 0000000..17bee9b
--- /dev/null
+++ b/test/cht-verify-i18n/main.go
@@ -0,0 +1,82 @@
+package main
+
+// issue2 驗證:用引擎 reader 取出「遊戲實際會顯示」的建築描述 / 法術描述 / help 本體,
+// 逐條丟 font.TranslateFormat(走 translateForDisplay 查表),統計多少已翻成中文。
+// 跑法:xvfb + cwd=LBX 目錄。
+
+import (
+	"fmt"
+	"strings"
+
+	"github.com/kazzmir/master-of-magic/lib/lbx"
+	"github.com/kazzmir/master-of-magic/lib/font"
+	"github.com/kazzmir/master-of-magic/game/magic/building"
+	helplib "github.com/kazzmir/master-of-magic/game/magic/help"
+	spelllib "github.com/kazzmir/master-of-magic/game/magic/spellbook"
+)
+
+func hasCJK(s string) bool {
+	for _, r := range s {
+		if r >= 0x4e00 && r <= 0x9fff {
+			return true
+		}
+	}
+	return false
+}
+
+func report(name string, sources []string) {
+	total, zh, sample := 0, 0, []string{}
+	seen := map[string]bool{}
+	for _, s := range sources {
+		if strings.TrimSpace(s) == "" || seen[s] {
+			continue
+		}
+		seen[s] = true
+		total++
+		out := font.TranslateFormat(s)
+		if hasCJK(out) {
+			zh++
+		} else if len(sample) < 5 {
+			one := s
+			if len(one) > 50 {
+				one = one[:50]
+			}
+			sample = append(sample, strings.ReplaceAll(one, "\x14", " "))
+		}
+	}
+	fmt.Printf("%s: %d/%d 已翻中文 (%.0f%%)\n", name, zh, total, float64(zh)*100/float64(total))
+	for _, s := range sample {
+		fmt.Printf("    未翻: %s\n", s)
+	}
+}
+
+func main() {
+	cache := lbx.AutoCache()
+
+	// 建築描述
+	if bd := building.MakeBuildDescriptions(cache); bd != nil {
+		var ds []string
+		for b := building.Building(1); b < building.BuildingLast; b++ {
+			ds = append(ds, bd.Get(b))
+		}
+		report("建築描述(buildesc.lbx)", ds)
+	}
+
+	// 法術描述
+	if sd, err := spelllib.ReadSpellDescriptionsFromCache(cache); err == nil {
+		report("法術描述(desc.lbx)", sd)
+	} else {
+		fmt.Println("spelldesc err:", err)
+	}
+
+	// help 本體
+	if lbxFile, err := cache.GetLbxFile("help.lbx"); err == nil {
+		if help, err := helplib.ReadHelp(lbxFile, 2); err == nil {
+			var hs []string
+			for _, e := range help.Entries {
+				hs = append(hs, e.Text)
+			}
+			report("help 本體(help.lbx)", hs)
+		}
+	}
+}
