diff --git a/game/magic/main_crashlog.go b/game/magic/main_crashlog.go
new file mode 100644
index 0000000..0c8783e
--- /dev/null
+++ b/game/magic/main_crashlog.go
@@ -0,0 +1,58 @@
+package main
+
+// 閃退 log(issue:閃退穩定性追查):引擎本來只把 log.Printf 輸出到 stderr,玩家雙擊 AppImage/.app
+// 執行時沒有主控台,閃退後現場全失。本檔把所有 log 同時導到持久檔 crash.log,並在 ebiten 的
+// Update/Draw 攔截 panic、寫下 panic 值與堆疊(落盤後再讓它照常崩潰),方便事後回收「閃退前最後發生什麼」。
+
+import (
+    "io"
+    "log"
+    "os"
+    "path/filepath"
+    "runtime/debug"
+)
+
+// crashLogDir 回傳可寫的 log 目錄(跨平台:Linux ~/.config、Windows %AppData%、mac App Support)。
+// AppImage(squashfs)/.app bundle 的 cwd 可能是唯讀掛載,故不寫 cwd。失敗時退回系統暫存目錄。
+func crashLogDir() string {
+    base, err := os.UserConfigDir()
+    if err != nil || base == "" {
+        base = os.TempDir()
+    }
+    dir := filepath.Join(base, "master-of-magic-cht")
+    if err := os.MkdirAll(dir, 0o755); err != nil {
+        return os.TempDir()
+    }
+    return dir
+}
+
+var crashLogFile *os.File
+
+// CrashLogPath 回傳目前 log 檔的完整路徑(供啟動時告知玩家位置)。
+func CrashLogPath() string {
+    return filepath.Join(crashLogDir(), "crash.log")
+}
+
+// setupCrashLog 把所有 log 輸出同時導到主控台與持久檔 crash.log。引擎大量以 log.Printf 記錄狀態轉換,
+// 落檔後閃退時即可看到「最後發生什麼」。回傳 log 檔路徑(開檔失敗則回空字串、僅輸出主控台)。
+func setupCrashLog() string {
+    path := CrashLogPath()
+    f, err := os.OpenFile(path, os.O_CREATE|os.O_APPEND|os.O_WRONLY, 0o644)
+    if err != nil {
+        log.Printf("crashlog: 無法開啟 log 檔 %v: %v(僅輸出到主控台)", path, err)
+        return ""
+    }
+    crashLogFile = f
+    log.SetOutput(io.MultiWriter(os.Stderr, f))
+    log.Printf("==== Master of Magic CHT 啟動;log 檔:%v ====", path)
+    return path
+}
+
+// logPanic 在 ebiten Update/Draw 攔截到 panic 時,把 panic 值與堆疊寫進 log 並落盤,
+// 供呼叫端 re-panic 維持原崩潰行為(只多了一份可回收的現場)。
+func logPanic(where string, r any) {
+    log.Printf("==== PANIC (%s): %v ====\n%s", where, r, debug.Stack())
+    if crashLogFile != nil {
+        _ = crashLogFile.Sync()
+    }
+}
