diff --git a/game/magic/util/image_override.go b/game/magic/util/image_override.go
new file mode 100644
index 0000000..5da75bf
--- /dev/null
+++ b/game/magic/util/image_override.go
@@ -0,0 +1,97 @@
+package util
+
+// 圖片覆蓋層 —— 工作魔法大帝中文化(處理「烘進 LBX 的圖片 UI 文字」)。
+//
+// 顯示層字串覆蓋 (lib/font) 只能換 font 繪製的文字;頂部選單 / 按鈕 / 畫面標題等是
+// 烘進版權 LBX 的點陣圖,font 覆蓋碰不到。本層在 ImageCache.GetImagesTransform 的單一
+// 載圖入口攔截:若某 (lbxFile, index) 有中文替換圖,改回傳中文版,版權 LBX 不動。
+//
+// 替換圖來源:環境變數 MOM_CHT_IMAGES 指向目錄,檔名規約 `<lbx>_<index>.png`
+// (lbx 去副檔名小寫,如 main.lbx index 12 -> main_12.png)。單張即覆蓋該 index 的所有 frame
+// 的第 0 張;多 frame 可用 `<lbx>_<index>_<frame>.png`。找不到則回退原圖,不影響英文。
+//
+// 探查:設 MOM_CHT_IMGLOG=<檔> 會把每個被請求的 (lbx,index,frameCount) 記下,
+// 供逐畫面定位哪張圖是哪個 UI 元素 (中文化美術的對照來源)。
+
+import (
+	"image/png"
+	"os"
+	"path/filepath"
+	"strconv"
+	"strings"
+	"sync"
+
+	"github.com/hajimehoshi/ebiten/v2"
+)
+
+var (
+	imgOverrideOnce sync.Once
+	imgOverrideDir  string
+	imgLogPath      string
+	imgLogMu        sync.Mutex
+	imgLogSeen      = map[string]bool{}
+)
+
+func initImageOverride() {
+	imgOverrideDir = os.Getenv("MOM_CHT_IMAGES")
+	imgLogPath = os.Getenv("MOM_CHT_IMGLOG")
+}
+
+// overrideImages 回傳 (lbxFile, index) 的中文替換圖;無替換時回傳 (nil, false)。
+func overrideImages(lbxPath string, index int) ([]*ebiten.Image, bool) {
+	imgOverrideOnce.Do(initImageOverride)
+
+	if imgLogPath != "" {
+		logImageRequest(lbxPath, index)
+	}
+	if imgOverrideDir == "" {
+		return nil, false
+	}
+
+	base := strings.TrimSuffix(strings.ToLower(lbxPath), ".lbx")
+	// 多 frame:<lbx>_<index>_<frame>.png 依序;否則單張 <lbx>_<index>.png
+	var out []*ebiten.Image
+	for frame := 0; ; frame++ {
+		p := filepath.Join(imgOverrideDir, base+"_"+strconv.Itoa(index)+"_"+strconv.Itoa(frame)+".png")
+		img := loadOverridePNG(p)
+		if img == nil {
+			break
+		}
+		out = append(out, img)
+	}
+	if len(out) > 0 {
+		return out, true
+	}
+	// 單張形式
+	if img := loadOverridePNG(filepath.Join(imgOverrideDir, base+"_"+strconv.Itoa(index)+".png")); img != nil {
+		return []*ebiten.Image{img}, true
+	}
+	return nil, false
+}
+
+func loadOverridePNG(path string) *ebiten.Image {
+	f, err := os.Open(path)
+	if err != nil {
+		return nil
+	}
+	defer f.Close()
+	img, err := png.Decode(f)
+	if err != nil {
+		return nil
+	}
+	return ebiten.NewImageFromImage(img)
+}
+
+func logImageRequest(lbxPath string, index int) {
+	imgLogMu.Lock()
+	defer imgLogMu.Unlock()
+	key := lbxPath + ":" + strconv.Itoa(index)
+	if imgLogSeen[key] {
+		return
+	}
+	imgLogSeen[key] = true
+	if f, err := os.OpenFile(imgLogPath, os.O_APPEND|os.O_CREATE|os.O_WRONLY, 0644); err == nil {
+		f.WriteString(key + "\n")
+		f.Close()
+	}
+}
diff --git a/lib/font/cjk.go b/lib/font/cjk.go
new file mode 100644
index 0000000..85d2fc0
--- /dev/null
+++ b/lib/font/cjk.go
@@ -0,0 +1,167 @@
+package font
+
+// CJK (繁體中文) glyph 支線 —— 工作魔法大帝中文化注入。
+//
+// 引擎原本只認 ASCII 32–127 (glyphIndex = int(c)-32);非 ASCII rune 在 doPrint /
+// PrintOutline / MeasureTextWidth 被靜默跳過。這裡提供「碼點 >= 0x2E80 改用 TTF rasterize
+// 的 glyph」這條支線,由 font.go 的繪字迴圈在 glyphIndex 超範圍時呼叫。
+//
+// 字級對齊 (Phase 2):CJK glyph 依「呼叫端字型的字高」rasterize,讓中英基線與行高一致、
+// 不破版。快取以 (rune, height) 為 key,face 以 height 為 key 各建一份。
+//
+// 字型來源:環境變數 MOM_CHT_FONT 指向 CJK TTF/TTC (預設找常見系統路徑)。
+// 找不到字型時所有函式回傳零值,呼叫端退回原本「跳過」行為,不影響英文。
+
+import (
+	"image"
+	_ "embed"
+	"image/color"
+	"os"
+	"sync"
+
+	"github.com/hajimehoshi/ebiten/v2"
+	xfont "golang.org/x/image/font"
+	"golang.org/x/image/font/opentype"
+	"golang.org/x/image/font/sfnt"
+	"golang.org/x/image/math/fixed"
+)
+
+// 內嵌 CJK 字型子集 (只含譯文用到的字),standalone 出包不依賴系統字型/env。
+//
+//go:embed cht_font.otf
+var embeddedFont []byte
+
+// CJK glyph 相對 cell 高度的基線位置 (0..1)。Noto 等字型 ink 約佔 em 上方,0.82 上下置中且不裁切。
+const cjkBaselineRatio = 0.82
+
+var cjkCandidatePaths = []string{
+	"/usr/share/fonts/opentype/noto/NotoSansCJK-Regular.ttc",
+	"/usr/share/fonts/truetype/noto/NotoSansCJK-Regular.ttc",
+	"/System/Library/Fonts/PingFang.ttc", // macOS
+	"C:\\Windows\\Fonts\\msjh.ttc",       // Windows 微軟正黑
+}
+
+type cjkKey struct {
+	r rune
+	h int
+}
+
+var (
+	cjkOnce  sync.Once
+	cjkFont  *sfnt.Font
+	cjkMu    sync.Mutex
+	cjkFaces = map[int]xfont.Face{}       // height -> face
+	cjkCache = map[cjkKey]*ebiten.Image{} // (rune,height) -> glyph image
+	cjkAdv   = map[cjkKey]int{}           // (rune,height) -> advance (px)
+)
+
+// CJK / 全形標點等範圍 (簡化版,Phase 2 再細分)。
+func isCJK(r rune) bool {
+	return r >= 0x2E80
+}
+
+func loadCJKFont() {
+	paths := cjkCandidatePaths
+	if env := os.Getenv("MOM_CHT_FONT"); env != "" {
+		paths = append([]string{env}, paths...)
+	}
+	var data []byte
+	for _, p := range paths {
+		if b, err := os.ReadFile(p); err == nil {
+			data = b
+			break
+		}
+	}
+	if data == nil {
+		// fallback:內嵌字型子集 (standalone 出包)
+		data = embeddedFont
+	}
+	if len(data) == 0 {
+		return // 無字型:CJK 支線停用,退回原行為
+	}
+	tt, err := opentype.Parse(data)
+	if err != nil {
+		// .ttc (TrueType collection) 走 ParseCollection 取第 0 個 font
+		coll, cerr := opentype.ParseCollection(data)
+		if cerr != nil {
+			return
+		}
+		tt, err = coll.Font(0)
+		if err != nil {
+			return
+		}
+	}
+	cjkFont = tt
+}
+
+// cjkFaceFor 回傳對應字高的 face (lazy 建立並快取)。呼叫端須持有 cjkMu。
+func cjkFaceFor(height int) xfont.Face {
+	if f, ok := cjkFaces[height]; ok {
+		return f
+	}
+	f, err := opentype.NewFace(cjkFont, &opentype.FaceOptions{
+		Size: float64(height), DPI: 72, Hinting: xfont.HintingFull,
+	})
+	if err != nil {
+		return nil
+	}
+	cjkFaces[height] = f
+	return f
+}
+
+// cjkSupersample:CJK glyph 以 logical 字高的 SS 倍解析度 rasterize,呼叫端再用 scale/SS 畫,
+// 佔同樣 logical footprint 但有 SS 倍 source 細節 —— 避免「小字放大糊掉」(見規則 81)。
+const cjkSupersample = 4
+
+// cjkGlyphImage 回傳 rune 的高解析 glyph image (height*SS 高) 與 logical 前進寬度 (height 單位,未乘 scale)。
+// 呼叫端須以 GeoM.Scale(scale/cjkSupersample, ...) 繪製。字型不可用或非 CJK 時回傳 (nil, 0)。
+func cjkGlyphImage(r rune, height int) (*ebiten.Image, int) {
+	cjkOnce.Do(loadCJKFont)
+	if cjkFont == nil || !isCJK(r) || height <= 0 {
+		return nil, 0
+	}
+
+	cjkMu.Lock()
+	defer cjkMu.Unlock()
+
+	key := cjkKey{r, height}
+	if img, ok := cjkCache[key]; ok {
+		return img, cjkAdv[key]
+	}
+
+	ss := cjkSupersample
+	hi := height * ss // supersample 渲染尺寸
+	face := cjkFaceFor(hi)
+	if face == nil {
+		return nil, 0
+	}
+
+	advance, ok := face.GlyphAdvance(r)
+	if !ok {
+		return nil, 0
+	}
+	advPx := advance.Round() // SS 解析下的前進寬
+	if advPx <= 0 {
+		advPx = hi
+	}
+	wLogical := (advPx + ss/2) / ss // 換回 logical 前進寬
+	if wLogical <= 0 {
+		wLogical = height
+	}
+
+	// cell:寬 = SS 解析前進寬,高 = height*SS;框在字高內對齊行高
+	rgba := image.NewRGBA(image.Rect(0, 0, advPx, hi))
+	baseline := int(float64(hi) * cjkBaselineRatio)
+	d := &xfont.Drawer{
+		Dst:  rgba,
+		Src:  image.NewUniform(color.White),
+		Face: face,
+		Dot:  fixed.P(0, baseline),
+	}
+	d.DrawString(string(r))
+
+	img := ebiten.NewImageFromImage(rgba)
+	cjkCache[key] = img
+	cjkAdv[key] = wLogical
+	return img, wLogical
+}
