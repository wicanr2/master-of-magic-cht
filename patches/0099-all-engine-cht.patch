new file mode 100644
index 0000000..7833963
--- /dev/null
+++ b/game/magic/player/advice.go
@@ -0,0 +1,60 @@
+package player
+
+// 自動建議(對應原版 Automatic Advice)。規則由《Master of Magic》玩家攻略(GameFAQs/the-spoiler、
+// MoM Fandom/StrategyWiki 機制頁、Steam/Reddit 社群指南、lilura1)跨多份歸納而來——皆為「可由遊戲
+// 狀態機械判斷」的核心建議。本層只產生「結構化建議」(AdviceType + 相關城市),不碰文字/翻譯,方便
+// 不跑遊戲就單元測試;訊息文字與顯示在 game 套件處理。
+//
+// 收支三項(金幣/食物/法力 per turn)由呼叫端先算好傳入(game 已有對應計算),避免本函式依賴
+// power/enchantment provider,讓判斷邏輯純粹可測。
+
+import (
+    citylib "github.com/kazzmir/master-of-magic/game/magic/city"
+)
+
+type AdviceType int
+
+const (
+    AdviceNegativeGold AdviceType = iota // 帝國金幣每回合為負 → 將強制解散單位
+    AdviceNegativeFood                   // 帝國食物每回合為負 → 部隊將餓死/解散
+    AdviceNegativeMana                   // 帝國法力每回合為負 → 結界/召喚將消失
+    AdviceNoResearch                     // 沒有研究中的法術(研究空轉)
+    AdviceCityRebels                     // 某城市有叛亂人口
+    AdviceCityNoGarrison                 // 某城市無守軍(無法防禦)
+)
+
+// Advice:一條建議。City 僅在城市相關建議時非 nil。
+type Advice struct {
+    Type AdviceType
+    City *citylib.City
+}
+
+// GenerateAdvice 依目前狀態產生建議清單。goldPerTurn/foodPerTurn/manaPerTurn 為帝國每回合淨收支。
+func (player *Player) GenerateAdvice(goldPerTurn int, foodPerTurn int, manaPerTurn int) []Advice {
+    var advice []Advice
+
+    if goldPerTurn < 0 {
+        advice = append(advice, Advice{Type: AdviceNegativeGold})
+    }
+    if foodPerTurn < 0 {
+        advice = append(advice, Advice{Type: AdviceNegativeFood})
+    }
+    if manaPerTurn < 0 {
+        advice = append(advice, Advice{Type: AdviceNegativeMana})
+    }
+    if !player.ResearchingSpell.Valid() {
+        advice = append(advice, Advice{Type: AdviceNoResearch})
+    }
+
+    for _, city := range player.GetCities() {
+        if city.Rebels > 0 {
+            advice = append(advice, Advice{Type: AdviceCityRebels, City: city})
+        }
+        // 守軍:該城所在格沒有本玩家的 stack = 無守軍。攻略:至少 1 單位才能嘗試防禦。
+        if player.FindStack(city.X, city.Y, city.Plane) == nil {
+            advice = append(advice, Advice{Type: AdviceCityNoGarrison, City: city})
+        }
+    }
+
+    return advice
+}
