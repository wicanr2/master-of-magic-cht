+package main
+
+// 抽 music.lbx 的 XMI → 標準 MIDI 檔(供 fluidsynth + SoundFont 離線算成推廣片配樂)。
+// 跑法:cwd = LBX 目錄(AutoCache)。輸出 /out/song_<idx>.mid。
+
+import (
+	"fmt"
+	"os"
+
+	"github.com/kazzmir/master-of-magic/lib/lbx"
+	"github.com/kazzmir/master-of-magic/lib/xmi"
+)
+
+func main() {
+	cache := lbx.AutoCache()
+	// 104=SongTitle(經典主題曲)、99=SongBackground1(大地圖)、112=SongIntro
+	for _, idx := range []int{104, 99, 112} {
+		song, err := xmi.ReadMidiFromCache(cache, "music.lbx", idx)
+		if err != nil {
+			fmt.Printf("idx %d: ERR %v\n", idx, err)
+			continue
+		}
+		out := fmt.Sprintf("/out/song_%d.mid", idx)
+		if err := song.WriteFile(out); err != nil {
+			fmt.Printf("idx %d write ERR %v\n", idx, err)
+			continue
+		}
+		fi, _ := os.Stat(out)
+		fmt.Printf("idx %d -> %s (%d bytes)\n", idx, out, fi.Size())
+	}
+}
