diff --git a/test/crt-verify/main.go b/test/crt-verify/main.go
new file mode 100644
index 0000000..6c3078e
--- /dev/null
+++ b/test/crt-verify/main.go
@@ -0,0 +1,147 @@
+package main
+
+// CRT shader headless 驗證 harness:把設定畫面(有 LBX 背景)渲染到離屏,經 game/magic/crt.kage
+// 後製後 dump PNG,證明 shader 在真實 xvfb GPU 下能編譯成功且產生掃描線/光罩/暗角效果。
+// 跑法:cwd 指向遊戲 LBX 目錄,xvfb 下執行。
+//   CRT=1 SHOT=/out/crt-on.png   → 套 shader
+//   CRT=0 SHOT=/out/crt-off.png  → 不套(對照組)
+// 著色器原始碼路徑由 KAGE 環境變數給(預設 /src/game/magic/crt.kage)。
+
+import (
+    "image"
+    "image/png"
+    "log"
+    "os"
+
+    "github.com/kazzmir/master-of-magic/lib/lbx"
+    "github.com/kazzmir/master-of-magic/game/magic/settings"
+    "github.com/kazzmir/master-of-magic/game/magic/audio"
+    musiclib "github.com/kazzmir/master-of-magic/game/magic/music"
+    "github.com/kazzmir/master-of-magic/game/magic/data"
+    "github.com/kazzmir/master-of-magic/game/magic/util"
+    "github.com/kazzmir/master-of-magic/game/magic/scale"
+    uilib "github.com/kazzmir/master-of-magic/game/magic/ui"
+    "github.com/kazzmir/master-of-magic/game/magic/mouse"
+
+    "github.com/hajimehoshi/ebiten/v2"
+)
+
+type Engine struct {
+    UI        *uilib.UI
+    counter   int
+    outPath   string
+    useCrt    bool
+    shader    *ebiten.Shader
+    offscreen *ebiten.Image
+}
+
+func NewEngine() (*Engine, error) {
+    cache := lbx.AutoCache()
+    imageCache := util.MakeImageCache(cache)
+    music := musiclib.MakeMusic(cache)
+
+    ui := &uilib.UI{
+        Draw: func(ui *uilib.UI, screen *ebiten.Image) {
+            ui.IterateElementsByLayer(func(element *uilib.UIElement) {
+                if element.Draw != nil {
+                    element.Draw(element, screen)
+                }
+            })
+        },
+    }
+    ui.SetElementsFromArray(nil)
+
+    group, _ := settings.MakeSettingsUI(cache, &imageCache, music)
+    ui.AddGroup(group)
+
+    out := os.Getenv("SHOT")
+    if out == "" {
+        out = "/out/crt.png"
+    }
+
+    engine := &Engine{UI: ui, outPath: out, useCrt: os.Getenv("CRT") == "1"}
+
+    if engine.useCrt {
+        kagePath := os.Getenv("KAGE")
+        if kagePath == "" {
+            kagePath = "/src/game/magic/crt.kage"
+        }
+        src, err := os.ReadFile(kagePath)
+        if err != nil {
+            log.Printf("read kage: %v", err)
+            os.Exit(1)
+        }
+        shader, err := ebiten.NewShader(src)
+        if err != nil {
+            log.Printf("FAIL: CRT shader 編譯失敗: %v", err)
+            os.Exit(2)
+        }
+        engine.shader = shader
+        log.Printf("CRT shader 編譯成功")
+    }
+
+    return engine, nil
+}
+
+func (engine *Engine) Update() error {
+    engine.UI.StandardUpdate()
+    engine.counter++
+    return nil
+}
+
+func (engine *Engine) Draw(screen *ebiten.Image) {
+    if engine.useCrt {
+        ow, oh := scale.Scale2(data.ScreenWidth, data.ScreenHeight)
+        if engine.offscreen == nil {
+            engine.offscreen = ebiten.NewImage(ow, oh)
+        }
+        engine.offscreen.Clear()
+        engine.UI.Draw(engine.UI, engine.offscreen)
+
+        op := &ebiten.DrawRectShaderOptions{}
+        op.Images[0] = engine.offscreen
+        op.Uniforms = map[string]any{"Scanlines": float32(data.ScreenHeight)}
+        screen.DrawRectShader(ow, oh, engine.shader, op)
+    } else {
+        engine.UI.Draw(engine.UI, screen)
+    }
+
+    if engine.counter == 20 {
+        bounds := screen.Bounds()
+        buf := make([]byte, 4*bounds.Dx()*bounds.Dy())
+        screen.ReadPixels(buf)
+        img := &image.NRGBA{Pix: buf, Stride: 4 * bounds.Dx(), Rect: image.Rect(0, 0, bounds.Dx(), bounds.Dy())}
+        f, err := os.Create(engine.outPath)
+        if err != nil {
+            log.Printf("create png: %v", err)
+            os.Exit(1)
+        }
+        if err := png.Encode(f, img); err != nil {
+            log.Printf("encode png: %v", err)
+        }
+        f.Close()
+        log.Printf("wrote %v (%dx%d)", engine.outPath, bounds.Dx(), bounds.Dy())
+        os.Exit(0)
+    }
+}
+
+func (engine *Engine) Layout(outsideWidth, outsideHeight int) (int, int) {
+    return scale.Scale2(data.ScreenWidth, data.ScreenHeight)
+}
+
+func main() {
+    log.SetFlags(log.Lshortfile)
+    ebiten.SetWindowSize(data.ScreenWidth*3, data.ScreenHeight*3)
+    ebiten.SetWindowTitle("crt-verify")
+    audio.Initialize()
+    mouse.Initialize()
+
+    engine, err := NewEngine()
+    if err != nil {
+        log.Printf("init: %v", err)
+        return
+    }
+    if err := ebiten.RunGame(engine); err != nil {
+        log.Printf("run: %v", err)
+    }
+}
