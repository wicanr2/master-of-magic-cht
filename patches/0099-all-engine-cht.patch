new file mode 100644
index 0000000..2a93c3d
--- /dev/null
+++ b/game/magic/spellbook/cht_spellorder_test.go
@@ -0,0 +1,77 @@
+package spellbook
+
+// 驗證 issue #7:法術書可按「顏色」排序而非「類別」(對應原版 MoM「Spell Book Ordering」設定,手冊 p.24)。
+// SpellBookOrderByColor=false(預設)→ 按 Section 分節;=true → 按 Magic 顏色分節。純顯示偏好。
+
+import (
+    "testing"
+
+    "github.com/kazzmir/master-of-magic/game/magic/data"
+)
+
+func TestChtSpellBookOrdering(test *testing.T) {
+    defer func() { SpellBookOrderByColor = false }() // 還原全域偏好
+
+    var spells Spells
+    // 跨顏色 + 跨類別的混合法術
+    spells.AddSpell(Spell{Name: "Nature A", Magic: data.NatureMagic, Section: SectionSummoning})
+    spells.AddSpell(Spell{Name: "Chaos A", Magic: data.ChaosMagic, Section: SectionSummoning})
+    spells.AddSpell(Spell{Name: "Nature B", Magic: data.NatureMagic, Section: SectionCitySpell})
+    spells.AddSpell(Spell{Name: "Sorcery A", Magic: data.SorceryMagic, Section: SectionCombatSpell})
+    spells.AddSpell(Spell{Name: "Chaos B", Magic: data.ChaosMagic, Section: SectionCombatSpell})
+
+    // === 預設:按類別(Section)分節 → 每頁法術同 Section ===
+    SpellBookOrderByColor = false
+    byCategory := computeHalfPages(spells, 6)
+    if len(byCategory) == 0 {
+        test.Fatalf("按類別分頁不應為空")
+    }
+    for _, page := range byCategory {
+        first := page.Spells.Spells[0].Section
+        for _, s := range page.Spells.Spells {
+            if s.Section != first {
+                test.Errorf(">>> 按類別模式:同一頁出現不同 Section(%v vs %v)", s.Section, first)
+            }
+        }
+    }
+
+    // === 切換:按顏色(Magic)分節 → 每頁法術同 Magic ===
+    SpellBookOrderByColor = true
+    byColor := computeHalfPages(spells, 6)
+    if len(byColor) == 0 {
+        test.Fatalf("按顏色分頁不應為空")
+    }
+    for _, page := range byColor {
+        first := page.Spells.Spells[0].Magic
+        for _, s := range page.Spells.Spells {
+            if s.Magic != first {
+                test.Errorf(">>> 按顏色模式:同一頁出現不同 Magic(%v vs %v)", s.Magic, first)
+            }
+        }
+    }
+
+    // 按顏色模式下,Nature 那一頁應含兩個 Nature 法術(原本分屬不同 Section,現合併)
+    natureCount := 0
+    for _, page := range byColor {
+        if page.Spells.Spells[0].Magic == data.NatureMagic {
+            natureCount += len(page.Spells.Spells)
+        }
+    }
+    if natureCount != 2 {
+        test.Errorf(">>> 按顏色模式:Nature 法術數應為 2(跨 Section 合併),得 %d", natureCount)
+    }
+
+    // 兩種模式的法術總數應一致(只是分組方式不同)
+    countPages := func(pages []Page) int {
+        n := 0
+        for _, p := range pages {
+            n += len(p.Spells.Spells)
+        }
+        return n
+    }
+    if countPages(byCategory) != countPages(byColor) {
+        test.Errorf(">>> 兩模式法術總數不一致:類別=%d 顏色=%d", countPages(byCategory), countPages(byColor))
+    }
+
+    test.Logf("法術書排序:按類別/按顏色切換正確,分組互斥、總數守恆 → #7 Spell Book Ordering 可用")
+}
