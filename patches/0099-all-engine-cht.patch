+package data
+
+// 執行期遊戲設定(對應原版《魔法大帝》Settings 畫面的部分項目)。
+// 目前為全域 runtime 偏好,不隨存檔序列化、重啟重置 —— 與音量、法術書排序同模式。
+// 預設值對齊原版預設:音效開、隨機事件開、戰略戰鬥(全自動結算)關。
+//
+// 放在 data 套件(最底層、人人可 import)以避免 import cycle:
+// settings 畫面(寫)與 game/ui(讀)都能存取,不需互相 import。
+type GameSettings struct {
+    SoundEffects        bool // #1 介面音效開關
+    RandomEvents        bool // #9 隨機事件(火山/地震/好月壞月等)
+    StrategicCombatOnly bool // #11 所有戰鬥自動結算,不進戰術戰鬥畫面(仍顯示勝負結果)
+    SpellAnimations     bool // #16 法術成功施放後的特效動畫(關閉=直接套用效果、跳過動畫)
+    ShowNodeOwners      bool // #17 已控魔法節點周圍顯示控制巫師旗色的光環(sparkle 影響範圍)
+    // 施法事件通知(對手玩家施法完成時通知人類玩家;依法術類別分別開關)
+    CitySpellEvents     bool // #4 城市結界類法術
+    OverlandSpellEvents bool // #5 戰略地圖(全域)結界類法術
+    SummoningEvents     bool // #6 召喚類法術
+    EnemySpells         bool // #14 其餘對手法術(catch-all)
+    // #12 戰鬥中顯示當前單位的額外資訊(剩餘彈藥/法力/血量),對應原版 Additional Unit Information
+    AdditionalUnitInformation bool
+    // 自動結束回合:開啟時所有單位用完移動即自動推進回合。對應原版 End of Turn Wait(關=自動推進);
+    // 此處用正向旗標(開=自動),預設關 → 維持手動點下一回合的現況。
+    AutoEndTurn bool
+    // #7 回合總結:人類新回合開始時自動彈出總結卷軸(內容同 Chancellor 顧問)。預設關。
+    EndOfTurnSummary bool
+    // #13 顯示敵軍移動:AI 單位移動到人類視野內時播放移動動畫。預設開(維持引擎現況)。
+    EnemyMoves bool
+    // #8 自動建議:人類回合開始時提示該注意的事(規則由 MoM 攻略歸納)。預設關(進階玩家會關掉)。
+    AutomaticAdvice bool
+    // DOS 原版觀感:把畫面垂直拉伸 1.2 倍還原原版 320×200 在 4:3 CRT 上的長寬比(見 docs/dos-vs-remake-ui.md)。
+    // 預設關(維持方形像素 16:10)。純顯示層,不影響遊戲邏輯;輸入座標會一併校正。
+    DosAspect bool
+    // CRT 質感 shader:掃描線 / 子像素光罩 / 暗角,模擬老 CRT 觀感(見 docs/crt-shader-guide.md)。
+    // 預設關。純顏色後製,不影響遊戲邏輯與滑鼠座標。
+    CrtShader bool
+    // 隱藏未研發法術:開啟時,法術書中尚未研發的法術描述顯示「未研發,無法顯示」(取代原版 alien 加密字型);
+    // 關閉時一律顯示完整描述(便於查閱)。預設開(貼近原版「未學會看不懂」,但用乾淨訊息取代亂碼)。
+    HideUnresearchedSpells bool
+}
+
+// DosAspectStretch:DOS 原版 320×200 在 4:3 CRT 上的垂直拉伸係數(PAR 1:1.2)。
+// 機制見 docs/dos-vs-remake-ui.md:Mode 13h 實際掃 400 線、每列像素佔兩條掃描線。
+const DosAspectStretch = 1.2
+
+var Settings = GameSettings{
+    SoundEffects:        true,
+    RandomEvents:        true,
+    StrategicCombatOnly: false,
+    SpellAnimations:     true,
+    ShowNodeOwners:      true,
+    CitySpellEvents:     true,
+    OverlandSpellEvents: true,
+    SummoningEvents:     true,
+    EnemySpells:         true,
+    AdditionalUnitInformation: true,
+    AutoEndTurn:         false, // 預設關:維持手動點下一回合
+    EndOfTurnSummary:    false, // 預設關:不自動彈總結
+    EnemyMoves:          true,  // 預設開:維持引擎現況(視野內敵軍移動有動畫)
+    AutomaticAdvice:     false, // 預設關:進階玩家會關掉(手冊語)
+    DosAspect:           false, // 預設關:維持方形像素;開啟還原 DOS 4:3 觀感
+    CrtShader:           false, // 預設關:開啟疊 CRT 掃描線/光罩/暗角質感
+    HideUnresearchedSpells: true, // 預設開:未研發法術顯示「未研發,無法顯示」(取代原版亂碼)
+}
