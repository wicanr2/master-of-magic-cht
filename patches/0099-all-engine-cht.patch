+}
+
+func TestChtGenerateAdvice(test *testing.T) {
+    player := MakePlayer(setup.WizardCustom{Banner: data.BannerRed}, true, 1, 1, make(map[herolib.HeroType]string), &NoGlobalEnchantments{})
+    player.ResearchingSpell = spellbook.Spell{Name: "Fireball"} // 有研究 → 不觸發 NoResearch
+
+    // 健康狀態:正收支、有研究、無城市 → 無建議
+    if advice := player.GenerateAdvice(5, 5, 5); len(advice) != 0 {
+        test.Errorf("健康狀態不應有建議,得 %d 條", len(advice))
+    }
+
+    // 三項收支為負 → 三條建議
+    advice := player.GenerateAdvice(-1, -1, -1)
+    if !hasAdvice(advice, AdviceNegativeGold) {
+        test.Errorf("金幣為負應建議")
+    }
+    if !hasAdvice(advice, AdviceNegativeFood) {
+        test.Errorf("食物為負應建議")
+    }
+    if !hasAdvice(advice, AdviceNegativeMana) {
+        test.Errorf("法力為負應建議")
+    }
+
+    // 沒有研究中的法術 → 建議
+    player.ResearchingSpell = spellbook.Spell{}
+    if !hasAdvice(player.GenerateAdvice(5, 5, 5), AdviceNoResearch) {
+        test.Errorf("無研究應建議")
+    }
+    player.ResearchingSpell = spellbook.Spell{Name: "Fireball"}
+
+    // 城市有叛亂 + 無守軍 → 兩條城市建議
+    city := &citylib.City{Name: "Testville", X: 5, Y: 5, Plane: data.PlaneArcanus, Rebels: 2}
+    player.AddCity(city)
+    advice = player.GenerateAdvice(5, 5, 5)
+    if !hasAdvice(advice, AdviceCityRebels) {
+        test.Errorf("城市有叛亂應建議")
+    }
+    if !hasAdvice(advice, AdviceCityNoGarrison) {
+        test.Errorf("城市無守軍應建議")
+    }
+
+    // 在城市放守軍 → 不再建議無守軍(但仍有叛亂建議)
+    unit := units.MakeOverworldUnit(units.HighMenSpearmen, 5, 5, data.PlaneArcanus)
+    player.AddUnit(unit)
+    advice = player.GenerateAdvice(5, 5, 5)
+    if hasAdvice(advice, AdviceCityNoGarrison) {
+        test.Errorf("已有守軍不應再建議無守軍")
+    }
+    if !hasAdvice(advice, AdviceCityRebels) {
+        test.Errorf("仍有叛亂應持續建議")
+    }
+
+    // 叛亂清零 → 不再建議叛亂
+    city.Rebels = 0
+    if hasAdvice(player.GenerateAdvice(5, 5, 5), AdviceCityRebels) {
+        test.Errorf("無叛亂不應建議")
+    }
+
+    test.Logf("自動建議規則:收支三負、無研究、城市叛亂/無守軍 皆正確觸發與解除")
+}
diff --git a/game/magic/player/cht_books_test.go b/game/magic/player/cht_books_test.go
new file mode 100644
index 0000000..b55121f
--- /dev/null
+++ b/game/magic/player/cht_books_test.go
@@ -0,0 +1,53 @@
+package player
+
+// 驗證 issue #6/#8:法術可用性是否依持有書系過濾。
+// 結論(本測試證明):研究池嚴格依 player.Wizard.Books 過濾——無某系書 = 該系 0 法術。
+// 故玩家「沒紅書卻有混沌法術」「選生命書戰鬥卻有死亡法術」並非研究洩漏,
+// 而是英雄/物品的 spell charges(合法 MoM 機制,不受書系限制),非引擎 bug。
+// 手冊 oracle(p.82,英雄能力「*Inherent Spell Knowledge」):
+//   "Spells accessible to the hero (such spells are not necessarily part of the wizard's
+//    spell book); these spells appear during combat."
+// → 手冊明載英雄內在法術不必然在巫師法術書、且於戰鬥中出現,與引擎行為一致。程式碼+手冊雙重佐證。
+
+import (
+    "fmt"
+    "testing"
+
+    "github.com/kazzmir/master-of-magic/game/magic/data"
+    "github.com/kazzmir/master-of-magic/game/magic/setup"
+    "github.com/kazzmir/master-of-magic/game/magic/spellbook"
+    "github.com/kazzmir/master-of-magic/game/magic/hero"
+)
+
+func TestChtResearchBookGating(test *testing.T) {
+    // 只有 Nature 書 (5 本),沒有 Chaos / Death 書
+    wizard := setup.WizardCustom{
+        Books: []data.WizardBook{
+            {Magic: data.NatureMagic, Count: 5},
+        },
+    }
+    player := MakePlayer(wizard, true, 1, 1, make(map[hero.HeroType]string), &NoGlobalEnchantments{})
+
+    var spells spellbook.Spells
+    for i := range 10 {
+        spells.AddSpell(spellbook.Spell{Name: fmt.Sprintf("nature %d", i), Magic: data.NatureMagic, Rarity: spellbook.SpellRarityCommon})
+        spells.AddSpell(spellbook.Spell{Name: fmt.Sprintf("chaos %d", i), Magic: data.ChaosMagic, Rarity: spellbook.SpellRarityCommon})
+        spells.AddSpell(spellbook.Spell{Name: fmt.Sprintf("death %d", i), Magic: data.DeathMagic, Rarity: spellbook.SpellRarityCommon})
+    }
+
+    player.InitializeResearchableSpells(&spells)
+
+    nature := player.ResearchPoolSpells.GetSpellsByMagic(data.NatureMagic)
+    chaos := player.ResearchPoolSpells.GetSpellsByMagic(data.ChaosMagic)
+    death := player.ResearchPoolSpells.GetSpellsByMagic(data.DeathMagic)
+
+    test.Logf("只有 Nature 書(5本) → 研究池: Nature=%d Chaos=%d Death=%d", len(nature.Spells), len(chaos.Spells), len(death.Spells))
+
+    if len(chaos.Spells) != 0 || len(death.Spells) != 0 {
+        test.Errorf("若這裡 >0 才是引擎 bug:無書系卻能研究其法術 (Chaos=%d Death=%d)", len(chaos.Spells), len(death.Spells))
+    }
+    if len(nature.Spells) == 0 {
+        test.Errorf("有 Nature 書卻無 Nature 研究法術")
+    }
+    test.Logf(">>> 研究 gating 正確:無書系=0 法術。#6/#8 的他系法術來自英雄 spell charges(合法 MoM),非 bug。")
+}
diff --git a/game/magic/player/cht_castcost_test.go b/game/magic/player/cht_castcost_test.go
new file mode 100644
index 0000000..4c4ea66
--- /dev/null
+++ b/game/magic/player/cht_castcost_test.go
@@ -0,0 +1,37 @@
+package player
+
+// 驗證 issue #2 根因:存檔只存 CastingSpell.Name,丟失 Create Artifact 的 OverrideCost(=神器成本)。
+// 手冊確認:製作神器時間取決於神器法力成本。讀檔後成本退回 base → 貴神器幾回合做好、法力不足照做。
+// 本測試證明:(1) 序列化確實丟失 OverrideCost;(2) 另存的 CreateArtifact.Cost 可用來還原(即修正依據)。
+
+import (
+    "testing"
+
+    "github.com/kazzmir/master-of-magic/game/magic/setup"
+    "github.com/kazzmir/master-of-magic/game/magic/spellbook"
+    "github.com/kazzmir/master-of-magic/game/magic/artifact"
+    "github.com/kazzmir/master-of-magic/game/magic/hero"
+)
+
+func TestChtCastingSpellOverrideCostLost(test *testing.T) {
+    player := MakePlayer(setup.WizardCustom{}, true, 1, 1, make(map[hero.HeroType]string), &NoGlobalEnchantments{})
+
+    // 模擬:玩家正在製作一個 4000 成本的神器(CastingSpell 帶 OverrideCost)
+    player.CastingSpell = spellbook.Spell{Name: "Create Artifact", OverrideCost: 4000}
+    player.CastingSpellProgress = 46
+    player.CreateArtifact = &artifact.Artifact{Type: artifact.ArtifactTypeSword, Cost: 4000}
+
+    serialized := SerializePlayer(player)
+
+    test.Logf("序列化後 CastingSpell = %q (只存名字,OverrideCost 沒進序列化)", serialized.CastingSpell)
+    if serialized.CreateArtifact == nil {
+        test.Fatalf("CreateArtifact 未序列化,無法還原成本")
+    }
+    test.Logf("序列化後 CreateArtifact.Cost = %d (神器成本有另存 → 修正可從此還原 OverrideCost)", serialized.CreateArtifact.Cost)
+
+    if serialized.CreateArtifact.Cost != 4000 {
+        test.Errorf("CreateArtifact 成本應 4000,得 %d", serialized.CreateArtifact.Cost)
+    }
+    test.Logf(">>> bug:CastingSpell 只存名字 → 讀檔 FindByName 回 base spell(OverrideCost=0)→ 成本退回 base")
+    test.Logf(">>> 修正(serialize.go):讀檔後 CastingSpell=Create Artifact 時,從 CreateArtifact.Cost 還原 OverrideCost")
+}
diff --git a/game/magic/player/cht_endturn_test.go b/game/magic/player/cht_endturn_test.go
new file mode 100644
index 0000000..fe1180b
--- /dev/null
+++ b/game/magic/player/cht_endturn_test.go
@@ -0,0 +1,56 @@
+package player
+
+// 驗證「自動結束回合」(對應原版 End of Turn Wait)的核心判斷:玩家所有 stack 是否都已用完移動。
+// 不需跑遊戲——直接構造玩家 + 單位、設定移動力,單元測試 AllStacksOutOfMoves()。
+// 遊戲端的 hook(game.Update)在設定開啟、overworld 閒置、此函式為真時自動送出下一回合事件。
+
+import (
+    "testing"
+
+    "github.com/kazzmir/master-of-magic/game/magic/data"
+    herolib "github.com/kazzmir/master-of-magic/game/magic/hero"
+    "github.com/kazzmir/master-of-magic/game/magic/setup"
+    "github.com/kazzmir/master-of-magic/game/magic/units"
+    "github.com/kazzmir/master-of-magic/lib/fraction"
+)
+
+func TestChtAllStacksOutOfMoves(test *testing.T) {
+    player := MakePlayer(setup.WizardCustom{Banner: data.BannerRed}, true, 1, 1, make(map[herolib.HeroType]string), &NoGlobalEnchantments{})
+
+    // 沒有任何 stack → 視為全部動完(本回合無單位待命令)
+    if !player.AllStacksOutOfMoves() {
+        test.Errorf("無 stack 時應回 true(無單位待命令)")
+    }
+
+    // 加入一個有移動力的單位 → 並非全部動完
+    unit := units.MakeOverworldUnit(units.HighMenSpearmen, 5, 5, data.PlaneArcanus)
+    player.AddUnit(unit)
+    unit.SetMovesLeft(true, fraction.FromInt(1))
+
+    if player.AllStacksOutOfMoves() {
+        test.Errorf("有可移動單位時應回 false")
+    }
+
+    // 用完移動 → 全部動完
+    unit.SetMovesLeft(true, fraction.Zero())
+    if !player.AllStacksOutOfMoves() {
+        test.Errorf("單位用完移動後應回 true")
+    }
+
+    // 再加第二個仍有移動力的單位(不同位置 → 不同 stack)→ 又變成非全部動完
+    unit2 := units.MakeOverworldUnit(units.HighMenSpearmen, 9, 9, data.PlaneArcanus)
+    player.AddUnit(unit2)
+    unit2.SetMovesLeft(true, fraction.FromInt(1))
+    if player.AllStacksOutOfMoves() {
+        test.Errorf("第二個 stack 仍可移動時應回 false")
+    }
+
+    // 兩個都用完 → 全部動完
+    unit2.SetMovesLeft(true, fraction.Zero())
+    if !player.AllStacksOutOfMoves() {
+        test.Errorf("所有 stack 用完移動後應回 true")
+    }
+
+    test.Logf("AllStacksOutOfMoves 正確:無單位/全動完→true,任一 stack 尚可移動→false")
+    test.Logf("自動結束回合預設關閉(data.Settings.AutoEndTurn=false)→ 不改變現況;開啟才在此為真時自動推進")
+}
diff --git a/game/magic/player/cht_herodeath_test.go b/game/magic/player/cht_herodeath_test.go
new file mode 100644
index 0000000..b22643c
--- /dev/null
+++ b/game/magic/player/cht_herodeath_test.go
@@ -0,0 +1,98 @@
+package player
+
+// 驗證 issue #3:我方英雄在戰鬥中被打死、但因最後獲勝而「自動復活、好像沒被幹掉一樣」。
+//
+// 手冊 oracle(manual.pdf p.71):英雄是獨特存在,死了除非被復活否則就是死了 →
+// 戰死英雄不該因獲勝而回到名冊/滿血。
+//
+// 完整 doCombat 的戰後 reconciliation 內嵌在 game.go,且需要版權 LBX(MakeGame 需 lbxCache)
+// 才能跑完整 Game,單元測試拿不到。本測試改在 player 層**精確重現** doCombat(AttackerWin)
+// 對英雄做的兩步,驗證資料層不變式:
+//   (1) 存活 re-add(game.go:4778):僅 `GetHealth()>0` 的單位重新加回 stack(死亡英雄略過)。
+//   (2) killUnits  (game.go:4922):`GetHealth()<=0` → `player.RemoveUnit(unit)`。
+// 致死走 combat 真實路徑:ArmyUnit.TakeDamage 對 unit.Unit 呼叫 AdjustHealth(-damage),
+// 對英雄物件即 Hero.AdjustHealth → health<=0 時 SetStatus(StatusDead)。
+//
+// 結論斷言:戰死英雄結束時 Status==StatusDead、不在 Heroes 名冊、不在 AliveHeroes、未重回軍隊。
+// 若引擎有 #3 復活 bug,本測試會在對應斷言失敗。
+
+import (
+    "testing"
+
+    "github.com/kazzmir/master-of-magic/game/magic/data"
+    herolib "github.com/kazzmir/master-of-magic/game/magic/hero"
+    "github.com/kazzmir/master-of-magic/game/magic/setup"
+    "github.com/kazzmir/master-of-magic/game/magic/units"
+)
+
+func TestChtHeroDeathNotRevivedOnWin(test *testing.T) {
+    player := MakePlayer(setup.WizardCustom{Banner: data.BannerRed}, true, 1, 1, make(map[herolib.HeroType]string), &NoGlobalEnchantments{})
+
+    h := herolib.MakeHero(
+        units.MakeOverworldUnitFromUnit(units.HeroRakir, 1, 1, data.PlaneArcanus, data.BannerRed, player.MakeExperienceInfo(), player.MakeUnitEnchantmentProvider()),
+        herolib.HeroRakir, "Rakir")
+
+    if !player.AddHero(h, 1, 1, data.PlaneArcanus) {
+        test.Fatalf("AddHero 失敗")
+    }
+    h.SetStatus(herolib.StatusEmployed) // 模擬已雇用、在我方軍隊中作戰
+
+    // 戰前:英雄活著、在名冊、滿血
+    if h.GetHealth() <= 0 {
+        test.Fatalf("戰前英雄應滿血,得 %d", h.GetHealth())
+    }
+    if n := len(player.AliveHeroes()); n != 1 {
+        test.Fatalf("戰前應有 1 位存活英雄,得 %d", n)
+    }
+
+    stack := player.FindStack(1, 1, data.PlaneArcanus)
+    if stack == nil {
+        test.Fatalf("找不到英雄所在 stack")
+    }
+
+    // === 模擬戰鬥致死(combat 真實路徑)===
+    h.AdjustHealth(-h.GetMaxHealth())
+
+    if h.GetHealth() != 0 {
+        test.Fatalf("致死後血量應為 0,得 %d", h.GetHealth())
+    }
+    if h.Status != herolib.StatusDead {
+        test.Errorf(">>> 復活 bug 徵兆:英雄血量歸零卻非 StatusDead(得 %v)→ 戰後會被當存活", h.Status)
+    }
+
+    // === 重現 doCombat(AttackerWin)戰後 reconciliation ===
+    // (1) 存活 re-add:僅 GetHealth()>0 重新加回 stack。
+    var reAdded []units.StackUnit
+    for _, u := range stack.Units() {
+        if u.GetHealth() > 0 {
+            reAdded = append(reAdded, u)
+        }
+    }
+    // (2) killUnits:GetHealth()<=0 → player.RemoveUnit。
+    for _, u := range stack.Units() {
+        if u.GetHealth() <= 0 {
+            player.RemoveUnit(u)
+        }
+    }
+
+    // === 斷言:英雄沒有復活 ===
+    if h.Status != herolib.StatusDead {
+        test.Errorf(">>> 復活 bug:RemoveUnit 後英雄 Status=%v(期望 StatusDead);RemoveUnit 只在 StatusEmployed 時改 status,死亡英雄應保持 Dead", h.Status)
+    }
+    for i, slot := range player.Heroes {
+        if slot == h {
+            test.Errorf(">>> 復活 bug:戰死英雄仍留在 Heroes[%d] 名冊", i)
+        }
+    }
+    if n := len(player.AliveHeroes()); n != 0 {
+        test.Errorf(">>> 復活 bug:戰後 AliveHeroes=%d(期望 0,英雄已死)", n)
+    }
+    for _, u := range reAdded {
+        if u == units.StackUnit(h) {
+            test.Errorf(">>> 復活 bug:戰死英雄被重新加回我方軍隊")
+        }
+    }
+
+    test.Logf("英雄戰死後正確保持 StatusDead、移出 Heroes 名冊、未重回軍隊 → 資料層 reconciliation 無 #3 復活問題")
+    test.Logf("關鍵:Hero.AdjustHealth 在 health<=0 設 StatusDead;player.RemoveUnit 僅在 StatusEmployed 時改 Available,故不會把死亡英雄改回可用")
+}
