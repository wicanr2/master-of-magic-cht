@@ -0,0 +1,35 @@
+package main
+
+import (
+	"fmt"
+	"github.com/kazzmir/master-of-magic/lib/font"
+)
+
+func main() {
+	keys := []string{
+		"(spell not yet researched)", "Hide Unresearched Spells",
+		"turn", "turns", "and", ", ",
+		"Recruit", "Regular", "Veteran", "Elite", "Ultra Elite", "Champion",
+		"Create Outpost",
+		"Tax Per Population", "0 gold, 0% unrest", "1 gold, 20% unrest", "3 gold, 75% unrest",
+		"FLOATING ISLANDS", "ARMAGEDON", "BASILISKS", "CHIMERA", "HOLY LIGHT",
+	}
+	ok, bad := 0, 0
+	for _, k := range keys {
+		v := font.TranslateFormat(k)
+		hasCJK := false
+		for _, r := range v {
+			if r >= 0x4e00 && r <= 0x9fff {
+				hasCJK = true
+			}
+		}
+		if hasCJK {
+			ok++
+			fmt.Printf("✓ %-28q → %s\n", k, v)
+		} else {
+			bad++
+			fmt.Printf("✗ %-28q → %s (未翻)\n", k, v)
+		}
+	}
+	fmt.Printf("\n翻譯: %d ok / %d 未翻\n", ok, bad)
+}
