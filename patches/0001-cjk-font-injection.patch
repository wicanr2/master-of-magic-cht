@@ -166,6 +166,20 @@ func (font *Font) PrintOutline(destination *ebiten.Image, edgeShader *ebiten.Sha
 
         glyphIndex := int(c) - 32
         if glyphIndex >= len(font.Glyphs) || glyphIndex < 0 {
+            // CJK 支線:outline 路徑同樣需要中文 glyph (否則中文在 PrintOutline 被丟棄)
+            if cjkImage, cjkAdv := cjkGlyphImage(c); cjkImage != nil {
+                var options ebiten.DrawImageOptions
+                options.GeoM.Scale(scale, scale)
+                options.GeoM.Translate(useX, y)
+                options.ColorScale = colorScale
+                destination.DrawImage(cjkImage, &options)
+
+                shaderOptions.GeoM = options.GeoM
+                shaderOptions.Images[0] = cjkImage
+                destination.DrawRectShader(cjkImage.Bounds().Dx(), cjkImage.Bounds().Dy(), edgeShader, &shaderOptions)
+
+                useX += float64(cjkAdv+font.internalFont.HorizontalSpacing) * scale
+            }
             continue
         }
 
@@ -205,6 +219,22 @@ func (font *Font) doPrint(destination *ebiten.Image, x float64, y float64, scale
 
         glyphIndex := int(c) - 32
         if glyphIndex >= len(font.Glyphs) || glyphIndex < 0 {
+            // CJK 支線:碼點超出 ASCII glyph 範圍時,改用 TTF rasterize 的中文 glyph
+            if cjkImage, cjkAdv := cjkGlyphImage(c); cjkImage != nil {
+                var options ebiten.DrawImageOptions
+                options.GeoM.Scale(scale, scale)
+                options.GeoM.Translate(useX, y)
+                if dropShadow {
+                    options.GeoM.Translate(scale*distance, scale*distance)
+                    options.ColorScale = colorScale
+                    options.ColorScale.ScaleWithColor(shadowColor)
+                    destination.DrawImage(cjkImage, &options)
+                    options.GeoM.Translate(-scale*distance, -scale*distance)
+                }
+                options.ColorScale = colorScale
+                destination.DrawImage(cjkImage, &options)
+                useX += float64(cjkAdv+font.internalFont.HorizontalSpacing) * scale
+            }
             continue
         }
 
@@ -254,6 +284,10 @@ func (font *Font) MeasureTextWidth(text string, scale float64) float64 {
 
         glyphIndex := int(c) - 32
         if glyphIndex >= len(font.Glyphs) || glyphIndex < 0 {
+            // CJK 支線:中文 glyph 的寬度量測,讓置中/置右/換行計算正確
+            if _, cjkAdv := cjkGlyphImage(c); cjkAdv > 0 {
+                width += cjkAdv + font.internalFont.HorizontalSpacing
+            }
             continue
         }
 
diff --git a/test/cjk-render/main.go b/test/cjk-render/main.go
new file mode 100644
