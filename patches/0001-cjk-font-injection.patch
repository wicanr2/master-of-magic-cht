@@ -0,0 +1,121 @@
+package font
+
+// CJK (繁體中文) glyph 支線 —— 工作魔法大帝中文化注入。
+//
+// 引擎原本只認 ASCII 32–127 (glyphIndex = int(c)-32);非 ASCII rune 在 doPrint /
+// MeasureTextWidth 被靜默跳過。這裡提供「碼點 >= 0x2E80 改用 TTF rasterize 的 glyph」這條支線,
+// 由 font.go 的繪字迴圈在 glyphIndex 超範圍時呼叫。
+//
+// 字型來源:環境變數 MOM_CHT_FONT 指向 CJK TTF/TTC (預設找常見系統路徑)。
+// 找不到字型時所有函式回傳零值,doPrint 退回原本「跳過」行為,不影響英文。
+//
+// 設計刻意維持 deep module:對外只露 cjkGlyphImage / cjkAdvance,內部字型載入與快取自理。
+
+import (
+	"image"
+	"image/color"
+	"os"
+	"sync"
+
+	"github.com/hajimehoshi/ebiten/v2"
+	xfont "golang.org/x/image/font"
+	"golang.org/x/image/font/opentype"
+	"golang.org/x/image/math/fixed"
+)
+
+const (
+	cjkBasePixels = 16 // CJK glyph 基準渲染尺寸 (logical px);draw 時再乘 doPrint 的 scale
+	cjkCellHeight = 20
+	cjkBaseline   = 15
+)
+
+var cjkCandidatePaths = []string{
+	"/usr/share/fonts/opentype/noto/NotoSansCJK-Regular.ttc",
+	"/usr/share/fonts/truetype/noto/NotoSansCJK-Regular.ttc",
+	"/System/Library/Fonts/PingFang.ttc", // macOS
+	"C:\\Windows\\Fonts\\msjh.ttc",       // Windows 微軟正黑
+}
+
+var (
+	cjkOnce  sync.Once
+	cjkFace  xfont.Face
+	cjkMu    sync.Mutex
+	cjkCache = map[rune]*ebiten.Image{}
+)
+
+// CJK / 全形標點等範圍 (簡化版,Phase 2 再細分)。
+func isCJK(r rune) bool {
+	return r >= 0x2E80
+}
+
+func loadCJKFont() {
+	paths := cjkCandidatePaths
+	if env := os.Getenv("MOM_CHT_FONT"); env != "" {
+		paths = append([]string{env}, paths...)
+	}
+	var data []byte
+	for _, p := range paths {
+		if b, err := os.ReadFile(p); err == nil {
+			data = b
+			break
+		}
+	}
+	if data == nil {
+		return // 無字型:CJK 支線停用,退回原行為
+	}
+	tt, err := opentype.Parse(data)
+	if err != nil {
+		coll, cerr := opentype.ParseCollection(data)
+		if cerr != nil {
+			return
+		}
+		tt, err = coll.Font(0)
+		if err != nil {
+			return
+		}
+	}
+	face, err := opentype.NewFace(tt, &opentype.FaceOptions{
+		Size: cjkBasePixels, DPI: 72, Hinting: xfont.HintingFull,
+	})
+	if err != nil {
+		return
+	}
+	cjkFace = face
+}
+
+// cjkGlyphImage 回傳 rune 的預渲染 glyph image 與其前進寬度 (logical px,未乘 scale)。
+// 字型不可用或非 CJK 時回傳 (nil, 0),呼叫端應退回原 ASCII 處理。
+func cjkGlyphImage(r rune) (*ebiten.Image, int) {
+	cjkOnce.Do(loadCJKFont)
+	if cjkFace == nil || !isCJK(r) {
+		return nil, 0
+	}
+
+	cjkMu.Lock()
+	defer cjkMu.Unlock()
+
+	if img, ok := cjkCache[r]; ok {
+		adv, _ := cjkFace.GlyphAdvance(r)
+		return img, adv.Round()
+	}
+
+	adv, ok := cjkFace.GlyphAdvance(r)
+	if !ok {
+		return nil, 0
+	}
+	w := adv.Round()
+	if w <= 0 {
+		w = cjkBasePixels
+	}
+	rgba := image.NewRGBA(image.Rect(0, 0, w, cjkCellHeight))
+	d := &xfont.Drawer{
+		Dst:  rgba,
+		Src:  image.NewUniform(color.White),
+		Face: cjkFace,
+		Dot:  fixed.P(0, cjkBaseline),
+	}
+	d.DrawString(string(r))
+	img := ebiten.NewImageFromImage(rgba)
+	cjkCache[r] = img
+	return img, w
+}
