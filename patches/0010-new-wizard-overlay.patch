+// magicChtName 回傳魔法學派的繁體中文名稱，供「選擇 X 法術」標題使用。
+func magicChtName(magic data.MagicType) string {
+    switch magic {
+    case data.LifeMagic:    return "生命"
+    case data.SorceryMagic: return "魔法"
+    case data.NatureMagic:  return "自然"
+    case data.DeathMagic:   return "死亡"
+    case data.ChaosMagic:   return "混沌"
+    case data.ArcaneMagic:  return "秘法"
+    }
+    return magic.String()
+}
