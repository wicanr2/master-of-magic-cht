+// retortCht 把英文 Retort 名稱對應到繁體中文。ui.tsv 的字串覆蓋層只做精確整段比對,
+// 無法拆解 JoinAbilities 的組合字串,故在此本地維護顯示層譯名。
+var retortCht = map[data.Retort]string{
+    data.RetortAlchemy:       "煉金術",
+    data.RetortWarlord:       "戰爭領主",
+    data.RetortChanneler:     "傳送師",
+    data.RetortArchmage:      "大巫師",
+    data.RetortArtificer:     "造物師",
+    data.RetortConjurer:      "召喚師",
+    data.RetortSageMaster:    "智慧大師",
+    data.RetortMyrran:        "米羅人",
+    data.RetortDivinePower:   "神聖力量",
+    data.RetortFamous:        "聲名顯赫",
+    data.RetortRunemaster:    "符文大師",
+    data.RetortCharismatic:   "魅力超凡",
+}
+
+// joinAbilitiesCht 把 Retort 列表用頓號串成繁中字串,取代英文 JoinAbilities 的顯示輸出。
+func joinAbilitiesCht(abilities []data.Retort) string {
+    parts := make([]string, 0, len(abilities))
+    for _, r := range abilities {
+        if zh, ok := retortCht[r]; ok {
+            parts = append(parts, zh)
+        } else {
+            parts = append(parts, r.String()) // fallback 英文
+        }
+    }
+    return strings.Join(parts, "、")
+}
