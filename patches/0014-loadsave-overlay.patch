diff --git a/test/loadscreen/main.go b/test/loadscreen/main.go
new file mode 100644
--- /dev/null
+++ b/test/loadscreen/main.go
@@ -0,0 +1,137 @@
+package main
+
+// 讀取/儲存畫面截圖測試 (中文化驗證)
+// 建立 gamemenu UI stub，靜置數 frames，截圖到 /out/loadscreen.png。
+// 全部存槽為空，驗證「空」標籤、「讀取 / 儲存進度」標題、按鈕中文。
+
+import (
+	"image"
+	"image/png"
+	"io"
+	"log"
+	"os"
+
+	"github.com/hajimehoshi/ebiten/v2"
+	"github.com/hajimehoshi/ebiten/v2/inpututil"
+
+	"github.com/kazzmir/master-of-magic/game/magic/data"
+	"github.com/kazzmir/master-of-magic/game/magic/gamemenu"
+	"github.com/kazzmir/master-of-magic/game/magic/scale"
+	"github.com/kazzmir/master-of-magic/game/magic/serialize"
+	uilib "github.com/kazzmir/master-of-magic/game/magic/ui"
+	"github.com/kazzmir/master-of-magic/lib/lbx"
+	"github.com/kazzmir/master-of-magic/lib/system"
+)
+
+// stub GameLoader — 全部空槽
+type stubLoader struct{}
+
+func (s *stubLoader) Load(_ io.Reader) error                               { return nil }
+func (s *stubLoader) LoadNew(_ string) error                               { return nil }
+func (s *stubLoader) LoadNewReader(_ io.Reader) error                      { return nil }
+func (s *stubLoader) LoadMetadata(_ string) (serialize.SaveMetadata, bool) { return serialize.SaveMetadata{}, false }
+func (s *stubLoader) GetFS() system.WriteableFS                             { return nil }
+
+type stubSaver struct{}
+
+func (s *stubSaver) SaveToPath(_ string, _ string) error { return nil }
+
+type stubSettings struct{}
+
+func (s *stubSettings) RunSettingsUI() {}
+
+// Engine
+type Engine struct {
+	ui     *uilib.UI
+	frames int
+	output string
+}
+
+func NewEngine(output string) (*Engine, error) {
+	cache := lbx.AutoCache()
+
+	group, _ := gamemenu.MakeGameMenuUI(
+		cache,
+		&stubLoader{},
+		&stubSaver{},
+		&stubSettings{},
+		func() {},
+	)
+
+	ui := &uilib.UI{}
+	ui.SetElementsFromArray(nil)
+	ui.AddGroup(group)
+
+	return &Engine{
+		ui:     ui,
+		output: output,
+	}, nil
+}
+
+func (e *Engine) Update() error {
+	keys := inpututil.AppendJustPressedKeys(nil)
+	for _, k := range keys {
+		if k == ebiten.KeyEscape {
+			return ebiten.Termination
+		}
+	}
+	e.ui.StandardUpdate()
+	e.frames++
+	if e.frames > 4 {
+		return ebiten.Termination
+	}
+	return nil
+}
+
+func (e *Engine) Draw(screen *ebiten.Image) {
+	e.ui.StandardDraw(screen)
+	if e.frames == 3 {
+		e.saveScreenshot(screen)
+	}
+}
+
+func (e *Engine) saveScreenshot(screen *ebiten.Image) {
+	w, h := screen.Bounds().Dx(), screen.Bounds().Dy()
+	pixels := make([]byte, w*h*4)
+	screen.ReadPixels(pixels)
+	rgba := image.NewRGBA(image.Rect(0, 0, w, h))
+	copy(rgba.Pix, pixels)
+
+	f, err := os.Create(e.output)
+	if err != nil {
+		log.Printf("Error creating output: %v", err)
+		return
+	}
+	defer f.Close()
+	if err := png.Encode(f, rgba); err != nil {
+		log.Printf("Error encoding PNG: %v", err)
+		return
+	}
+	log.Printf("Screenshot saved → %v (%dx%d)", e.output, w, h)
+}
+
+func (e *Engine) Layout(_, _ int) (int, int) {
+	return scale.Scale2(data.ScreenWidth, data.ScreenHeight)
+}
+
+func main() {
+	log.SetFlags(log.Ldate | log.Lshortfile | log.Lmicroseconds)
+
+	output := "/out/loadscreen.png"
+	if len(os.Args) > 1 {
+		output = os.Args[1]
+	}
+
+	engine, err := NewEngine(output)
+	if err != nil {
+		log.Printf("Error: %v", err)
+		return
+	}
+
+	ebiten.SetWindowSize(data.ScreenWidth*3, data.ScreenHeight*3)
+	ebiten.SetWindowTitle("loadscreen-CHT")
+
+	if err := ebiten.RunGame(engine); err != nil && err != ebiten.Termination {
+		log.Printf("Error: %v", err)
+	}
+}
